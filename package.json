{
  "name": "division2-gear-calculator",
  "version": "1.8.24",
  "description": "Division 2 Gear & DPS Calculator",
  "main": "main.js",
  "author": "ImThatTeryaki",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "prebuild": "node backup-dist.js",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.sleepyinc.div2calc",
    "productName": "Division 2 Gear Calculator",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": null,
      "sign": null,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "splash-liquid-glass.html",
      "splash-aero.html",
      "splash-aero-nightshade.html",
      "welcome.html",
      "welcome-liquid-glass.html",
      "welcome-aero.html",
      "welcome-aero-nightshade.html",
      "division2-gear-calculator-v2.html",
      "screenshot.html",
      "build-advisor-worker.js",
      "assets/**/*",
      "html2canvas.min.js",
      "icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "prettier": "^3.8.1"
  }
}
